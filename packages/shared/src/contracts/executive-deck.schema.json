{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://googleads.local/schemas/executive-deck.schema.json",
  "title": "ExecutiveDeck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "deck_id",
    "tenant_id",
    "client_id",
    "report_type",
    "period_reference",
    "audience",
    "headline",
    "slides",
    "generated_at"
  ],
  "properties": {
    "deck_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "client_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "report_type": {
      "type": "string",
      "enum": ["weekly", "monthly"]
    },
    "period_reference": {
      "$ref": "#/$defs/periodReference"
    },
    "audience": {
      "type": "string",
      "enum": ["executive", "client", "marketing"]
    },
    "headline": {
      "type": "string",
      "minLength": 10,
      "maxLength": 180
    },
    "slides": {
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/slide"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "periodReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["period_label", "period_start", "period_end", "baseline_label"],
      "properties": {
        "period_label": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "period_start": {
          "type": "string",
          "format": "date"
        },
        "period_end": {
          "type": "string",
          "format": "date"
        },
        "baseline_label": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 120
        }
      }
    },
    "highlight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "context"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "context": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 180
        }
      }
    },
    "chartSeriesPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "value": {
          "type": "number"
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "points"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 31,
          "items": {
            "$ref": "#/$defs/chartSeriesPoint"
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chart_type", "title", "x_label", "y_label", "series"],
      "properties": {
        "chart_type": {
          "type": "string",
          "enum": ["line", "bar", "stacked_bar", "kpi_strip", "none"]
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "x_label": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 80
        },
        "y_label": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 80
        },
        "series": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/chartSeries"
          }
        }
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slide_id",
        "slide_type",
        "title",
        "main_message",
        "bullets",
        "highlights",
        "chart",
        "speaker_note"
      ],
      "properties": {
        "slide_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "slide_type": {
          "type": "string",
          "enum": ["cover_summary", "trend", "winners", "gaps", "diagnosis", "action_plan", "next_steps"]
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "main_message": {
          "type": "string",
          "minLength": 15,
          "maxLength": 220
        },
        "bullets": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 180
          }
        },
        "highlights": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/highlight"
          }
        },
        "chart": {
          "anyOf": [
            {
              "$ref": "#/$defs/chart"
            },
            {
              "type": "null"
            }
          ]
        },
        "speaker_note": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 400
        }
      }
    }
  }
}
