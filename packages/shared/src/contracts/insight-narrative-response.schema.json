{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://googleads.local/schemas/insight-narrative-response.schema.json",
  "title": "InsightNarrativeResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "responseVersion",
    "title",
    "diagnosis",
    "primaryHypothesis",
    "recommendedAction",
    "expectedImpact",
    "priority",
    "confidence",
    "correlationType",
    "evidenceRefs",
    "dataLimitations",
    "technicalOutput",
    "executiveOutput"
  ],
  "properties": {
    "responseVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 191
    },
    "diagnosis": {
      "type": "string",
      "minLength": 20,
      "maxLength": 600
    },
    "primaryHypothesis": {
      "type": "string",
      "minLength": 10,
      "maxLength": 400
    },
    "recommendedAction": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },
    "expectedImpact": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "correlationType": {
      "type": "string",
      "enum": ["confirmed", "probable", "correlated_only", "insufficient_data"]
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 64
      }
    },
    "dataLimitations": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 240
      }
    },
    "technicalOutput": {
      "$ref": "#/$defs/outputBlock"
    },
    "executiveOutput": {
      "$ref": "#/$defs/outputBlock"
    }
  },
  "$defs": {
    "outputBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "explanation", "nextStep", "caution"],
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "explanation": {
          "type": "string",
          "minLength": 20,
          "maxLength": 600
        },
        "nextStep": {
          "type": "string",
          "minLength": 5,
          "maxLength": 200
        },
        "caution": {
          "type": ["string", "null"],
          "minLength": 0,
          "maxLength": 200
        }
      }
    }
  }
}
