# =========================================================
# ENVIRONMENT
# =========================================================
# Runtime principal da aplicacao.
# Valores esperados: development | test | staging | production
NODE_ENV=development

# Ambiente de negocio/deploy.
# Valores esperados: development | staging | production
APP_ENV=development

# Habilita logs e comportamentos mais verbosos em ambiente local.
# Em staging/producao, use false.
APP_DEBUG=true


# =========================================================
# APP URLS
# =========================================================
# URL publica do backend.
APP_BASE_URL=http://localhost:3000

# URL publica do frontend web.
WEB_BASE_URL=http://localhost:5173

# Prefixo global das rotas HTTP da API.
API_PREFIX=api


# =========================================================
# API SERVER
# =========================================================
# Host de bind do servidor HTTP.
API_HOST=0.0.0.0

# Porta do servidor HTTP.
API_PORT=3000

# Quantidade maxima de requests por proxy confiavel.
# Ajuste para true somente se houver load balancer ou reverse proxy confiavel.
API_TRUST_PROXY=false

# Limite maximo do corpo HTTP aceito pela API, em bytes.
# Reduz o risco de abuso por payloads grandes demais.
API_REQUEST_BODY_LIMIT_BYTES=1048576


# =========================================================
# DATABASE
# =========================================================
# String de conexao principal com o banco.
# Exemplo esperado: mysql://user:password@host:3306/database_name
DATABASE_URL=mysql://change-user:change-password@127.0.0.1:3306/google_ads_saas

# Database auxiliar para migracoes/operacoes administrativas, se necessario.
# Pode ser igual a DATABASE_URL no inicio.
DATABASE_MIGRATION_URL=mysql://change-user:change-password@127.0.0.1:3306/google_ads_saas

# Tamanho maximo desejado do pool de conexoes.
DATABASE_POOL_MAX=10

# Tamanho minimo desejado do pool de conexoes.
DATABASE_POOL_MIN=1

# Timeout de query em milissegundos para operacoes demoradas.
DATABASE_QUERY_TIMEOUT_MS=15000


# =========================================================
# AUTHENTICATION
# =========================================================
# Nome do cookie principal de sessao.
SESSION_COOKIE_NAME=__Host-sid

# Nome do cookie de CSRF usado pelo frontend.
CSRF_COOKIE_NAME=__Host-xsrf

# Segredo usado para assinar/validar cookies e sessao.
# Use no minimo 32 caracteres aleatorios.
APP_COOKIE_SECRET=change-me-with-at-least-32-random-characters

# Tempo maximo sem atividade antes de expirar a sessao.
SESSION_IDLE_TTL_MINUTES=480

# Tempo maximo absoluto da sessao, mesmo com atividade.
SESSION_ABSOLUTE_TTL_MINUTES=1440

# Tempo de validade da elevacao de privilegio para acoes sensiveis.
STEP_UP_AUTH_TTL_MINUTES=15

# Habilita MFA obrigatorio para perfis privilegiados.
AUTH_ENFORCE_MFA_FOR_PRIVILEGED_USERS=true

# Numero maximo de tentativas de login antes de bloqueio temporario.
AUTH_MAX_LOGIN_ATTEMPTS=5

# Janela em minutos para controle de brute force.
AUTH_LOGIN_WINDOW_MINUTES=15

# Duracao do bloqueio temporario apos exceder tentativas.
AUTH_LOGIN_LOCKOUT_MINUTES=15


# =========================================================
# CRYPTOGRAPHY
# =========================================================
# Chave principal de criptografia da aplicacao.
# Use uma chave de 32 bytes codificada conforme sua implementacao.
APP_ENCRYPTION_KEY=base64:replace-with-32-byte-key

# Chave anterior para rotacao gradual de segredos.
# Pode ficar vazia enquanto nao houver rotacao.
APP_PREVIOUS_ENCRYPTION_KEY=

# Pepper extra para hashing de artefatos sensiveis.
# Nao deve ser igual ao APP_COOKIE_SECRET.
APP_HASH_PEPPER=change-me-with-another-random-secret

# Algoritmo de criptografia em repouso para tokens e segredos.
APP_ENCRYPTION_ALGORITHM=AES-256-GCM


# =========================================================
# GOOGLE OAUTH
# =========================================================
# Client ID OAuth da aplicacao cadastrada no Google Cloud.
GOOGLE_CLIENT_ID=replace-me

# Client Secret OAuth da aplicacao cadastrada no Google Cloud.
GOOGLE_CLIENT_SECRET=replace-me

# Redirect URI exata cadastrada no Google Cloud.
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/integrations/google-ads/callback

# Escopos requisitados durante a conexao com Google Ads.
# Mantenha o minimo necessario.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords

# Solicita refresh token de longa duracao.
GOOGLE_OAUTH_ACCESS_TYPE=offline

# Prompt padrao para garantir consentimento quando necessario.
GOOGLE_OAUTH_PROMPT=consent

# Tempo de validade do state/nonce do OAuth em minutos.
GOOGLE_OAUTH_STATE_TTL_MINUTES=10


# =========================================================
# GOOGLE ADS API
# =========================================================
# Developer token da Google Ads API.
GOOGLE_ADS_DEVELOPER_TOKEN=replace-me

# Login customer ID padrao, quando a app operar via MCC.
# Pode ficar vazio se nao houver valor padrao global.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Versao alvo da Google Ads API.
GOOGLE_ADS_API_VERSION=v21

# Timeout de requisicao para chamadas na Google Ads API.
GOOGLE_ADS_TIMEOUT_MS=30000

# Numero maximo de retries para erros transientes.
GOOGLE_ADS_MAX_RETRIES=3

# Backoff inicial para retries da Google Ads API.
GOOGLE_ADS_RETRY_BASE_DELAY_MS=1000


# =========================================================
# TENANCY AND SECURITY
# =========================================================
# Estrategia de resolucao do tenant.
# Valores esperados: path | subdomain
TENANT_RESOLUTION_STRATEGY=path

# Exige tenant valido em todas as rotas protegidas.
TENANT_ENFORCE_MEMBERSHIP=true

# Habilita bloqueio de acesso cross-tenant.
TENANT_BLOCK_CROSS_ACCESS=true

# Habilita prefixo por tenant em cache, storage e export.
TENANT_REQUIRE_SCOPED_KEYS=true


# =========================================================
# REPORTS
# =========================================================
# Driver de armazenamento dos relatorios gerados.
# Valores esperados: local | s3
REPORT_STORAGE_DRIVER=local

# Diretorio base para armazenar arquivos de relatorio localmente.
REPORT_STORAGE_PATH=storage/reports

# Diretorio temporario para montagem de apresentacoes.
REPORT_TEMP_PATH=storage/tmp

# Formato padrao de saida para relatorios executivos.
# Valores esperados: pptx | pdf | html
REPORT_DEFAULT_FORMAT=pdf

# Tempo de expiracao do link ou arquivo gerado.
REPORT_EXPIRES_IN_HOURS=72


# =========================================================
# LOGGING AND AUDIT
# =========================================================
# Nivel padrao de log.
# Valores esperados: debug | info | warn | error
LOG_LEVEL=debug

# Formato principal dos logs.
# Valores esperados: pretty | json
LOG_FORMAT=pretty

# Habilita redacao e mascaramento automatico de segredos.
LOG_REDACT_SENSITIVE=true

# Habilita persistencia de eventos de auditoria.
AUDIT_LOG_ENABLED=true

# Habilita persistencia de eventos de seguranca.
SECURITY_EVENT_LOG_ENABLED=true

# Dias de retencao dos logs de auditoria.
AUDIT_LOG_RETENTION_DAYS=365

# Dias de retencao dos eventos de seguranca.
SECURITY_EVENT_RETENTION_DAYS=365


# =========================================================
# QUEUES AND JOBS
# =========================================================
# Driver da fila.
# Valores esperados: database | redis
QUEUE_DRIVER=database

# Quantidade de workers concorrentes.
QUEUE_CONCURRENCY=1

# Habilita o scheduler de jobs.
SCHEDULER_ENABLED=true

# Habilita worker de fila.
WORKER_ENABLED=true

# Quantidade maxima de tentativas por job.
JOB_MAX_ATTEMPTS=3

# Delay base para retry de jobs falhos.
JOB_RETRY_BASE_DELAY_MS=1000

# Timeout de execucao de um job em milissegundos.
JOB_TIMEOUT_MS=60000

# Cron de sincronizacao principal.
SYNC_SCHEDULE_CRON=*/15 * * * *

# Janela recente para reprocessar conversoes atrasadas.
SYNC_RECENT_REPROCESS_DAYS=14

# Janela inicial de backfill.
SYNC_INITIAL_BACKFILL_DAYS=90

# Numero maximo de contas Google Ads processadas em paralelo.
SYNC_MAX_ACCOUNTS_PER_RUN=5


# =========================================================
# INTERNAL RATE LIMITS
# =========================================================
# Limite por usuario para gerar relatorios executivos.
RATE_LIMIT_REPORTS_PER_HOUR=10

# Limite por conta para sync manual.
RATE_LIMIT_MANUAL_SYNC_PER_HOUR=2

# Limite por usuario para exportacoes.
RATE_LIMIT_EXPORTS_PER_HOUR=10


# =========================================================
# FRONTEND
# =========================================================
# URL base da API consumida pelo frontend.
VITE_API_BASE_URL=http://localhost:3000/api

# Nome exibido pela aplicacao web.
VITE_APP_NAME=Google Ads SaaS
