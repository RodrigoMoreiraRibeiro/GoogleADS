{
  "name": "@googleads/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prebuild": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -LiteralPath dist -Recurse -Force }\"",
    "build": "tsc -p tsconfig.json",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\..\\scripts\\start-api-dev.ps1 -Watch",
    "dev:plain": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\..\\scripts\\start-api-dev.ps1",
    "start": "node dist/apps/api/src/bootstrap/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node --import tsx --test src/modules/insights/application/agents/account-auditor.agent.test.ts src/modules/insights/application/agents/campaign-strategist.agent.test.ts src/modules/insights/application/agents/segmentation-specialist.agent.test.ts src/modules/insights/application/agents/search-terms-specialist.agent.test.ts src/modules/insights/application/agents/creative-performance.agent.test.ts src/modules/insights/application/agents/hypothesis-reviewer.agent.test.ts src/modules/insights/application/agents/executive-summary.agent.test.ts",
    "test:integration": "node --import tsx --test src/modules/insights/application/agents/performance-agent-orchestrator.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@googleads/shared": "0.1.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@prisma/client": "^6.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fastify": "^5.6.0",
    "pptxgenjs": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^6.15.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
